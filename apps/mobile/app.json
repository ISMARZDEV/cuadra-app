{
  "expo": {
    "name": "Cuadra",
    "slug": "cuadra",
    "scheme": "cuadra",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ismarzdev.cuadra"
    },
    "android": {
      "package": "com.ismarzdev.cuadra"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-audio",
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
