{
  "expo": {
    "name": "Cuadra",
    "slug": "cuadra",
    "scheme": "cuadra",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ismarzdev.cuadra"
    },
    "android": {
      "package": "com.ismarzdev.cuadra",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-audio",
      "expo-font",
      "expo-notifications",
      "@clerk/expo",
      "expo-web-browser",
      "./plugins/with-free-signing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7bf2f75c-e8ed-4f6e-8c39-c73a528c10f1"
      }
    },
    "owner": "ismartzdev"
  }
}
