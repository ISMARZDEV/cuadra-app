{
  "extends": "@cuadra/config/tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client", "@testing-library/jest-dom"],
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["pages", "layouts", "src", "vite.config.ts", "vitest.config.ts"]
}
